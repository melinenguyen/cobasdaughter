# === REQUIRED ===

# Anthropic / Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack (Bot Token + Channel)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX   # channel to post the daily digest

# === OPTIONAL (more sources = richer trends) ===

# Reddit API  →  https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TrendTracker/1.0

# Twitter / X API v2  →  https://developer.twitter.com/en/portal
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# YouTube Data API v3  →  https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_data_api_key

# === DASHBOARD ===
FLASK_SECRET_KEY=change-me-to-a-random-string
DASHBOARD_PORT=5050
REPORTS_DIR=reports

# === SCHEDULER ===
# Timezone for daily 10 AM digest
SCHEDULER_TIMEZONE=America/New_York
