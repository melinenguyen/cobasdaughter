# ============================================================
# CoBa's Daughter — Trend Intelligence Agent
# ============================================================

# === REQUIRED ===

# Anthropic / Claude API  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack (Bot Token + your personal Member ID for DM)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=U0XXXXXXXXX   # Your Slack Member ID (for direct message)

# === OPTIONAL — more sources = richer trend data ===

# Reddit API  →  https://www.reddit.com/prefs/apps  (free)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=CoBasDaughter/1.0

# Twitter / X API v2  →  https://developer.twitter.com/en/portal  (paid)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# YouTube Data API v3  →  https://console.cloud.google.com/  (free tier)
YOUTUBE_API_KEY=your_youtube_data_api_key

# Instagram Graph API  →  https://developers.facebook.com/  (requires Business IG account)
# Step 1: Create a Facebook App at developers.facebook.com
# Step 2: Connect an Instagram Business/Creator account to a Facebook Page
# Step 3: Generate a long-lived User Access Token with instagram_basic,
#         instagram_manage_insights, pages_show_list permissions
# Step 4: Find your IG Business Account ID via:
#         GET https://graph.facebook.com/me/accounts?access_token=YOUR_TOKEN
INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_numeric_id

# === DASHBOARD ===
FLASK_SECRET_KEY=change-me-to-a-random-string
DASHBOARD_PORT=5050
REPORTS_DIR=reports
DASHBOARD_URL=http://localhost:5050

# === SCHEDULER ===
# Timezone for 9 AM and 3 PM digest
SCHEDULER_TIMEZONE=America/New_York
